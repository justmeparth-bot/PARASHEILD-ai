{
  "entities": {
    "Rider": {
      "title": "Rider",
      "description": "A rider account in the RiderGuard system.",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string",
          "description": "The unique Firebase Auth UID of the rider."
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "The rider's email address."
        },
        "displayName": {
          "type": "string",
          "description": "The rider's full name."
        },
        "photoURL": {
          "type": "string",
          "format": "uri",
          "description": "The rider's profile picture URL."
        },
        "vehicleType": {
          "type": "string",
          "enum": ["E-bike", "Scooter", "Motorcycle", "Car", "Bicycle"],
          "description": "The type of vehicle the rider uses."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the account was created."
        },
        "role": {
          "type": "string",
          "enum": ["rider", "admin"],
          "description": "The user's role in the system."
        }
      },
      "required": ["uid", "email", "role"]
    }
  },
  "firestore": {
    "riders/{riderId}": {
      "schema": "Rider",
      "description": "Collection of rider profiles."
    }
  }
}
